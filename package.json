{
  "name": "emoot-humber-capstone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "test": "vitest run",
    "emulators": "firebase emulators:start --only firestore --project emoot-my-savings-goal",
    "emulators:persist": "firebase emulators:start --only firestore --project emoot-my-savings-goal --import=./.emulator-data --export-on-exit=./.emulator-data",
    "seed:emulator": "SEED_TARGET=emulator tsx scripts/seed/seed.ts",
    "seed:prod": "SEED_TARGET=prod tsx scripts/seed/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/permanent-marker": "^5.2.7",
    "@fontsource/quicksand": "^5.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "shadcn": "^4.8.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^14.0.0",
    "firebase-tools": "^15.21.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
